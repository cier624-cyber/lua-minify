            player.CameraMode = Enum.CameraMode.Classic
            camera.CameraType = Enum.CameraType.Custom
            
            
            player.DevEnableMouseLock = true
        else
            
            player.CameraMode = _G.OriginalCameraMode
        end
    end
end

