_G.EspActive = false


local function cleanupESP()
    _G.EspActive = false
    if _G.EspConnection then _G.EspConnection:Disconnect() _G.EspConnection = nil end
    if _G.EspPlayerAdded then _G.EspPlayerAdded:Disconnect() _G.EspPlayerAdded = nil end
    
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Character then
            if p.Character:FindFirstChild("PUMP_Highlight") then
                p.Character.PUMP_Highlight:Destroy()
            end
            if p.Character:FindFirstChild("Head") and p.Character.Head:FindFirstChild("PUMP_Billboard") then
                p.Character.Head.PUMP_Billboard:Destroy()
            end
        end
    end
end


local function applyESP(targetPlayer)
    if targetPlayer == game.Players.LocalPlayer then return end
    
    local function onCharacter(char)
        if not _G.EspActive or not char then return end
        
        
        if not char:IsDescendantOf(workspace) then
            char.AncestryChanged:Wait()
        end
        task.wait(0.5) 
        
        
        local hl = char:FindFirstChild("PUMP_Highlight")
        if not hl then
            hl = Instance.new("Highlight")
            hl.Name = "PUMP_Highlight"
            hl.FillColor = Color3.fromRGB(0, 213, 255)  
            hl.FillTransparency = 0.5                  
            hl.OutlineColor = Color3.fromRGB(255, 255, 255) 
            hl.OutlineTransparency = 0                  
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
            hl.Parent = char
        end
        
        
        local head = char:WaitForChild("Head", 10) -- เพิ่มเวลาส่องหาหัวเป็น 10 วินาทีป้องกันแมพโหลดช้า
        if head and not head:FindFirstChild("PUMP_Billboard") then
            local bill = Instance.new("BillboardGui")
            bill.Name = "PUMP_Billboard"
            bill.AlwaysOnTop = true
            bill.Size = UDim2.new(0, 200, 0, 50)
            bill.StudsOffset = Vector3.new(0, 2.5, 0) 
            bill.Parent = head
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, 0, 1, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            nameLabel.TextSize = 13
            nameLabel.Font = Enum.Font.SourceSansBold
            nameLabel.TextStrokeTransparency = 0 
            nameLabel.Parent = bill
            
            
            task.spawn(function()
                while _G.EspActive and char and char.Parent and head and head.Parent and hl and hl.Parent do
                    local localChar = game.Players.LocalPlayer.Character
                    local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    
                    if hrp and localHrp then
                        local distance = math.floor((hrp.Position - localHrp.Position).Magnitude)
                        nameLabel.Text = string.format("%s\n[%d m]", targetPlayer.Name, distance)
                    else
                        nameLabel.Text = targetPlayer.Name
                    end
                    task.wait(0.3) 
                end
            end)
        end
    end
    
    
    if targetPlayer.Character then
        task.spawn(function() onCharacter(targetPlayer.Character) end)
    end
    
    
    targetPlayer.CharacterAdded:Connect(function(char)
        task.spawn(function() onCharacter(char) end)
    end)
end


local function createESP()
    cleanupESP() 
    _G.EspActive = true
    
    for _, p in pairs(game.Players:GetPlayers()) do
        applyESP(p)
    end
    
    _G.EspPlayerAdded = game.Players.PlayerAdded:Connect(function(p)
        applyESP(p)
    end)
end

