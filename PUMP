                    _G.StdFlyBG.P = 9e4
                    _G.StdFlyBG.maxTorque = Vector3.new(9e9, 9e9, 9e9)
                    _G.StdFlyBG.cframe = hrp.CFrame
                    _G.StdFlyBG.Parent = hrp
                    
                    _G.StdFlyBV = Instance.new("BodyVelocity")
                    _G.StdFlyBV.velocity = Vector3.new(0, 0, 0)
                    _G.StdFlyBV.maxForce = Vector3.new(9e9, 9e9, 9e9)
                    _G.StdFlyBV.Parent = hrp
                    
                    _G.StdFlyLoop = game:GetService("RunService").Heartbeat:Connect(function()
                        if not IsFlying or not char or not hrp or not hum then return end
                        hum:ChangeState("None")
                        
                        local camera = workspace.CurrentCamera
                        local moveDir = hum.MoveDirection 
                        local userSpeed = tonumber(SpeedInput.Text) or 50
                        local actualSpeed = userSpeed * 0.9
                        
                        _G.StdFlyBG.cframe = camera.CFrame
                        
                        if moveDir.Magnitude > 0 then
                            local camCFrame = camera.CFrame
                            local lookVector = camCFrame.LookVector
                            local rightVector = camCFrame.RightVector
                            local direction = (lookVector * (moveDir:Dot(lookVector) / lookVector.Magnitude)) + (rightVector * (moveDir:Dot(rightVector) / rightVector.Magnitude))
                            
                            if direction.Magnitude > 0 then
                                _G.StdFlyBV.velocity = direction.Unit * actualSpeed
                            end
                        else
                            _G.StdFlyBV.velocity = Vector3.new(0, 0, 0)
                        end
                    end)
                else
                    FlyButton.BackgroundColor3 = Color3.fromRGB(255, 85, 85)
                    FlyButton.Text = "เริ่มบิน (OFF)"
                    cleanupStdFly()
                end
            end)
        else
    
